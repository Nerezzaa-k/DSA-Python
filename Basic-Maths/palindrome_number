# Problem: Check if a number is palindrome
# Platform: LeetCode
# Approach: Reverse the number and compare with original
# Edge Case: Negative numbers are not palindrome
# Time Complexity: O(log10 n)
# Space Complexity: O(1)

class Solution:
    def isPalindrome(self, x):
        
        # Negative numbers cannot be palindrome
        if x < 0:
            return False
        
        num = x
        result = 0
        
        while num > 0:
            ld = num % 10
            result = (result * 10) + ld
            num = num // 10
            
        return x == result


# Example test
obj = Solution()
print(obj.isPalindrome(121))   # True
print(obj.isPalindrome(-121))  # False
